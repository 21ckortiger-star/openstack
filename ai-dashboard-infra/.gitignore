# Local .terraform directories
**/.terraform/*

# .tfplan files
*.tfplan

# .tfstate files
*.tfstate
*.tfstate.*

# .terraform.lock.hcl (Often ignored in libraries, but can be kept in root projects.
# However, usually it's better to ignore state and its backups at least.)
# terraform.tfstate
# terraform.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude sensitive info
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc
